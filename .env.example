# Sous Chef — env template
# Copy this file to .env and fill in keys. Never commit .env.
# Each dev generates and holds their own keys.

# --- Backend keys ------------------------------------------------------------

# Groq — https://console.groq.com/keys
# Used for utterance processing (llama-3.1-8b-instant) and audio transcription (whisper-large-v3-turbo)
GROQ_API_KEY=

# ElevenLabs — https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
# Pick a voice from https://elevenlabs.io/app/voice-lab and paste the voice_id:
ELEVENLABS_VOICE_ID=

# Edamam Nutrition Analysis — https://developer.edamam.com/admin/applications
EDAMAM_APP_ID=
EDAMAM_APP_KEY=

# Supabase — https://supabase.com/dashboard/project/_/settings/api
# Use the SERVICE ROLE key on the backend (bypasses RLS). Never ship it to mobile.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Mobile (EXPO_PUBLIC_ prefix is required so the Expo bundler exposes them) --

# Backend base URL. Local dev: http://localhost:8000.
# Prod: copy the public domain from Railway dashboard → your service → Settings → Networking → Public Domain.
EXPO_PUBLIC_BACKEND_URL=http://localhost:8000

# Picovoice Porcupine — https://console.picovoice.ai/
# Also download the "hey chef" .ppn files (iOS + Android) into mobile/assets/
EXPO_PUBLIC_PORCUPINE_KEY=

# Flip to 1 for backend-free UI work
EXPO_PUBLIC_MOCK=0
