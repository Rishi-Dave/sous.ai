EXPO_PUBLIC_BACKEND_URL=http://localhost:8000
# Set to 1 to use mocked API responses and skip the real backend (UI-only work).
EXPO_PUBLIC_MOCK=0
# Picovoice Console access key for Porcupine wake-word detection.
# Rate-limiter key, not a high-value secret — but still .env-only, never committed.
# Get one at https://console.picovoice.ai/. EAS dev builds inherit via `eas env:create --environment development`.
EXPO_PUBLIC_PICOVOICE_ACCESS_KEY=
# Set to true to enable Porcupine in dev builds (requires access key and native module).
EXPO_PUBLIC_USE_PORCUPINE=false
# Hands-free wake without Porcupine: short clips POSTed to /wake_probe (Groq Whisper on backend).
# Default on; set to false to disable. Ignored when USE_PORCUPINE is true. Native only (not Expo web).
# EXPO_PUBLIC_USE_GROQ_WAKE_PROBE=false
